{
  "name": "prejudice",
  "version": "1.0.2",
  "description": "A JavaScript library that acts as a companion to Pride, both of which interface with the U-M Library search backend",
  "main": "lib/prejudice.js",
  "scripts": {
    "build": "npm run build:webpack && npm run build:prod",
    "build:dev": "npm run build:webpack -- --progress --color --watch",
    "build:prod": "npm run build:webpack -- --mode=production --env=build",
    "build:webpack": "webpack --mode=${mode:=development} $* --env ${env:=dev}",
    "lint": "eslint *.config.*js src/ $*",
    "lint:fix": "npm run lint -- --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlibrary/prejudice.git"
  },
  "keywords": [
    "webpack",
    "es6",
    "starter",
    "library",
    "universal",
    "umd",
    "commonjs"
  ],
  "author": "Krasimir Tsonev, Albert Bertram",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mlibrary/prejudice/issues"
  },
  "homepage": "https://github.com/mlibrary/prejudice#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.29.3",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "babel-loader": "^10.1.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "terser-webpack-plugin": "^5.5.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "idle-timeout": "^2.3.7",
    "reqwest": "^2.0.5",
    "xhr2": "^0.2.1"
  }
}
