{
  "name": "prejudice",
  "version": "1.0.2",
  "description": "Produce universal library with webpack and es6",
  "main": "lib/prejudice.min.js",
  "scripts": {
    "build": "npm run build:prod",
    "build:dev": "npm run build:esbuild -- --outfile=lib/prejudice.js --watch",
    "build:esbuild": "esbuild src/Prejudice.js --bundle --sourcemap --platform=browser --format=iife --global-name=prejudice",
    "build:prod": "npm run build:esbuild -- --minify --outfile=lib/prejudice.min.js",
    "lint": "npx eslint eslint.config.mjs src/ $*",
    "lint:fix": "npm run lint -- --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/krasimir/webpack-library-starter.git"
  },
  "keywords": [
    "webpack",
    "es6",
    "starter",
    "library",
    "universal",
    "umd",
    "commonjs"
  ],
  "author": "Krasimir Tsonev, Albert Bertram",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/krasimir/webpack-library-starter/issues"
  },
  "homepage": "https://github.com/krasimir/webpack-library-starter",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0"
  },
  "dependencies": {
    "idle-timeout": "^2.3.6",
    "reqwest": "^2.0.5",
    "xhr2": "^0.2.1"
  }
}
